{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "healthcheckPath": "/",
    "healthcheckTimeout": 120,
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 3,
    "numReplicas": 1
  },
  "volumes": [
    {
      "name": "mts-data",
      "mountPath": "/app/data",
      "sizeMB": 480
    }
  ]
}

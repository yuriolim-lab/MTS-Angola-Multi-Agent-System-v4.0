# MTS Angola Multi-Agent System - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE (SQLite)
# ===========================================
# Development
DATABASE_URL=file:./db/custom.db

# Production (Railway with persistent volume)
# DATABASE_URL=file:/app/data/mts_angola.db

# ===========================================
# SMTP EMAIL CONFIGURATION (Required)
# ===========================================
# Gmail example (enable 2FA and create App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Outlook/Office365 example
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@outlook.com
# SMTP_PASS=your-password

# ===========================================
# TWILIO WHATSAPP (Optional - for alerts only)
# ===========================================
# Only needed if you want WhatsApp alerts
# TWILIO_SID=your-account-sid
# TWILIO_TOKEN=your-auth-token
# TWILIO_PHONE=+14155238886
# MANAGER_PHONE=+244923456789

# ===========================================
# COMPANY INFORMATION
# ===========================================
COMPANY_NAME=MTS Angola
COMPANY_EMAIL=info@mtsangola.com

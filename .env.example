# ===========================================
# MTS ANGOLA MULTI-AGENT SYSTEM v4.0
# Environment Variables Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE (SQLite)
# ===========================================
# Development: local file
DATABASE_URL=file:./db/custom.db

# Production (Railway): persistent volume
# DATABASE_URL=file:/app/data/mts_angola.db

# ===========================================
# SMTP EMAIL CONFIGURATION (Required for Agents)
# ===========================================
# Gmail example (enable 2FA and create App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Outlook/Office365
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587

# Custom SMTP
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=465
# SMTP_SECURE=true

# ===========================================
# TWILIO WHATSAPP (Optional - Critical Alerts Only)
# ===========================================
# Only needed for WhatsApp alerts to manager
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_PHONE=
MANAGER_PHONE=

# ===========================================
# COMPANY INFORMATION
# ===========================================
COMPANY_NAME=MTS Angola
COMPANY_EMAIL=info@mtsangola.com

# ===========================================
# APPLICATION SETTINGS (Auto-configured)
# ===========================================
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
SKIP_ENV_VALIDATION=1
PORT=3000

# MTS Angola Multi-Agent System - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE (SQLite)
# ===========================================
DATABASE_URL=file:/app/data/mts_angola.db

# ===========================================
# SMTP EMAIL CONFIGURATION (Required)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ===========================================
# TWILIO WHATSAPP (Optional - for alerts only)
# ===========================================
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_PHONE=
MANAGER_PHONE=

# ===========================================
# COMPANY INFORMATION
# ===========================================
COMPANY_NAME=MTS Angola
COMPANY_EMAIL=info@mtsangola.com

# ===========================================
# APPLICATION SETTINGS (Auto-configured)
# ===========================================
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
SKIP_ENV_VALIDATION=1
